# Copy to .env and fill in real values for production builds. EXPO_PUBLIC_*
# vars are inlined into the JS bundle by Expo and treated as public — only
# put values that are safe to ship in the client (e.g. AdMob unit IDs,
# RevenueCat *public* SDK keys). Never put server-only secrets here.

# RevenueCat — public SDK keys per platform.
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# Google AdMob ad unit IDs. If left blank, the lib falls back to Google's
# well-known TEST IDs so dev builds never accidentally serve real ads.
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=
