{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "development"
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "preview"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "production"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "tim.hobrlant@gmail.com",
        "ascAppId": "6768260091",
        "appleTeamId": "J5PLN5P9Z2"
      },
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./.secrets/play-service-account.json"
      }
    },
    "production": {
      "ios": {
        "appleId": "tim.hobrlant@gmail.com",
        "ascAppId": "6768260091",
        "appleTeamId": "J5PLN5P9Z2"
      },
      "android": {
        "track": "production",
        "serviceAccountKeyPath": "./.secrets/play-service-account.json"
      }
    }
  }
}
